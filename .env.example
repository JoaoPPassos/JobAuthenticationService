# Application
PORT=3000
NODE_ENV=development
APP_NAME=JobHub
APP_URL=http://localhost:3000
LOGIN_URL=http://localhost:3000/login

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=jobauth

# JWT
HASH_TOKEN=your_jwt_secret_here
HASH_REFRESH_TOKEN=your_refresh_secret_here
EXPIRES_ACCESS_TOKEN=1d
EXPIRES_REFRESH_TOKEN=7d

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis (token validation cache) — run: docker compose up -d
REDIS_HOST=localhost
REDIS_PORT=6380

# Email credential encryption — must be a 64-char hex string (32 bytes AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_ENCRYPTION_KEY=your_64_char_hex_key_here
